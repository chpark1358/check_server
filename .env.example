# Public browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_ENV=local

# Server-only values. Never expose these with NEXT_PUBLIC_ prefixes.
SUPABASE_SERVICE_ROLE_KEY=
ZENDESK_SUBDOMAIN=jiransoft
ZENDESK_EMAIL=officetech2@jiran.com
ZENDESK_API_TOKEN=
ZENDESK_SUPPORT_ADDRESS=support@jiransoft.zendesk.com
ZENDESK_FIXED_ASSIGNEE_EMAIL=officetech2@jiran.com
SOLUTION_API_BASE_URL=https://sma.officekeeper.co.kr
SOLUTION_API_TOKEN=
ALLOW_REAL_ZENDESK_SEND=false
ZENDESK_DEFAULT_GROUP_ID=16839549064601
ZENDESK_DEFAULT_GROUP_NAME=솔루션팀

# DOCX → PDF 변환은 ConvertAPI(https://www.convertapi.com)로 위임합니다. 미설정 시 PDF 생성은 자동 비활성화되고 DOCX만 제공됩니다.
# 무료 250 변환/월. API Credentials 페이지에서 Bearer 토큰 발급 후 입력.
CONVERTAPI_TOKEN=

# Distributed rate limit (Vercel KV 또는 Upstash Redis). 미설정 시 in-process fallback으로 동작 (서버리스 환경에서는 효력 약함).
# 둘 중 한 쌍만 채우면 됩니다. Vercel KV를 프로젝트에 붙이면 KV_* 변수가 자동 주입됩니다.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 또는
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
